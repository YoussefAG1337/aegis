# --- Stage 1: Builder ---
FROM node:20-alpine AS builder

WORKDIR /app

# Enable corepack so we can manage packages if needed, but we'll stick to npm
COPY package*.json ./
RUN npm ci

# Copy the rest of the Next.js source code
COPY . .

# Build the Next.js application
# This will generate the optimized .next/standalone folder
RUN npm run build

# --- Stage 2: Production ---
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
# Next.js telemetry is annoying in production logs, let's disable it
ENV NEXT_TELEMETRY_DISABLED=1 

# Copy the public static assets (images, fonts, etc.)
COPY --from=builder /app/public ./public

# Copy the standalone Next.js server generated by the build
COPY --from=builder /app/.next/standalone ./
# Copy the static chunks Next.js generated
COPY --from=builder /app/.next/static ./.next/static

# Expose port 3000
EXPOSE 3000

# Next.js standalone outputs a server.js file by default
# We run it directly with Node!
CMD ["node", "server.js"]